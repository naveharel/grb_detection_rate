# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Test caches
.pytest_cache/

# Virtual environments
.venv/
venv/
ENV/
env/

# IDEs
.idea/
.vscode/

# OS files
.DS_Store
Thumbs.db

# Build / packaging
build/
dist/
*.egg-info/

# Outputs
*.png

# Generated publication figures (scripts are tracked; outputs are regenerated).
# Ignore the contents (incl. PDFs, which *.png above does not catch) but keep the
# directory via .gitkeep. Use /* not / so the negation can re-include .gitkeep.
figures/output/*
!figures/output/.gitkeep

# Physics reference documents (large PDFs, copyrighted)
sources/

# Claude Code context files (project-specific, not for version control)
.claude/
CLAUDE.md
docs/architecture.md
docs/physics_model.md
docs/ui_reference.md

# Stray home-directory paths accidentally tracked
~/.claude/
